{
  "name": "Python + Node.js Dev Base",
  "image": "ghcr.io/tomasvotava/dev-base:latest",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "29.2",
      "enableNonRootDocker": true,
      "moby": false
    }
  },
  "runArgs": [
    "--env-file",
    ".devcontainer/devcontainer.env"
  ],
  "mounts": [
    "source=${localWorkspaceFolderBasename}-bashhistory,target=/commandhistory,type=volume",
    "source=claude-global,target=/home/vscode/.claude,type=volume",
    "source=gemini-auth-global,target=/home/vscode/.config/Google,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "bierner.markdown-mermaid",
        "charliermarsh.ruff",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "github.codespaces",
        "github.vscode-github-actions",
        "google.geminicodeassist",
        "innoverio.vscode-dbt-power-user",
        "ms-azuretools.vscode-docker",
        "ms-python.mypy-type-checker",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "ms-vscode.makefile-tools",
        "sqlfluff.vscode-sqlfluff",
        "svelte.svelte-vscode",
        "tamasfe.even-better-toml",
        "vitest.explorer"
      ],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "python.analysis.typeCheckingMode": "strict",
        "ruff.interpreter": [
          ".venv/bin/python"
        ],
        "mypy-type-checker.interpreter": [
          ".venv/bin/python"
        ],
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}
